{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": [
    "kindeSrc/**/*.ts",
    "kindeSrc/**/*.tsx",
    "kindeSrc/**/*.d.ts",
    "dev/**/*.ts",
    "dev/**/*.tsx",
    "dev/**/*.d.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules"]
}
